# Comma-separated bearer tokens for API access (must start with pk_)
INFER_API_KEYS=pk_your_key_here

# Internal key for node agent registration
INFER_INTERNAL_KEY=internal_dev_secret

# Ollama backend URL
OLLAMA_URL=http://localhost:11434

# Port to listen on
PORT=8080

# Log level (error, warn, info, debug, trace)
RUST_LOG=api_gateway=debug,tower_http=info
