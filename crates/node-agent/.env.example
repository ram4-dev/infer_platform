# Human-readable name for this node
NODE_NAME=my-gpu-node

# Public IP/hostname that the coordinator can reach this node on
NODE_HOST=192.168.1.100

# Port where Ollama is running on this node
NODE_PORT=11434

# Port for the node agent's own HTTP server
AGENT_PORT=8181

# URL of the API gateway / coordinator
COORDINATOR_URL=http://coordinator.infer.ram4.dev

# Must match INFER_INTERNAL_KEY on the gateway
INFER_INTERNAL_KEY=internal_dev_secret

# Override GPU detection (optional)
# GPU_NAME=NVIDIA RTX 3080
# GPU_VRAM_MB=10240

RUST_LOG=node_agent=debug,tower_http=info
